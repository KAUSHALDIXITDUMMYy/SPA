# ─── Public (browser / frontend) ─────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://sportsmagicianaudio.vercel.app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase App Check (blocks clone sites). reCAPTCHA v3/Enterprise site key from
# Firebase Console → App Check. Leave blank to disable App Check on the client.
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=
# Local-dev only: debug token from the console so localhost can attest.
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Zoom Meeting SDK (public key only)
NEXT_PUBLIC_ZOOM_MEETING_SDK_KEY=

# ─── Server only (never expose to the browser) ────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=

# Set to "true" ONLY after App Check is enforcing in the Firebase Console and the
# client site key is live. Then the API rejects requests without a valid App Check
# token (i.e. clone sites). Deploy the code first with this unset, verify your real
# app still works, then flip to "true".
APPCHECK_ENFORCE=

# ─── API origin / clone-site filtering (comma-separated; optional) ────────────
# Leave blank to use the built-in defaults. Set these when your domains change so
# you don't have to edit code (e.g. after migrating to a new deployment URL).
# BLOCKED_API_HOSTS   — domains that must never call the API (clone/retransmit sites)
# ALLOWED_API_ORIGINS — browser origins allowed to call /api/*
# OWN_HOSTS            — hostnames that are legitimately your deployment
BLOCKED_API_HOSTS=
ALLOWED_API_ORIGINS=
OWN_HOSTS=

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_MEETING_SDK_SECRET=

AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=
