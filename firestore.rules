rules_version = '2';

// LOCKED DOWN — deny all direct client access.
//
// Every read/write now goes through our backend API routes, which use the Firebase
// Admin SDK. The Admin SDK bypasses these rules entirely, so the app keeps working
// while NO client (browser, mobile, or a clone site embedding our public config) can
// touch Firestore directly. This removes the previous vulnerability where any
// signed-in user could read/write the whole database.
//
// Publish in Firebase Console → Firestore → Rules → Publish (and via firebase deploy).
//
// If you ever add a feature that must read Firestore directly from the client, add a
// narrowly-scoped match block here for that specific collection/path only — never a
// broad `if signedIn()` rule.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
